# Variables de entorno para el deploy del marketplace
# Copiar a .env en el VPS y rellenar con valores reales.
# Este archivo NO se commitea al repo.

# ─────────────────────────────────────────────────
# Bases de datos (generar con: openssl rand -base64 32 | tr -d '/+=' | head -c 40)
# ─────────────────────────────────────────────────
PROD_PG_PASS=
DEV_PG_PASS=

# ─────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────
JWT_SECRET=
MASTER_USER=
MASTER_PASS=

# ─────────────────────────────────────────────────
# Servicios externos
# ─────────────────────────────────────────────────
RESEND_API_KEY=
STRIPE_SECRET_KEY=
PUBLIC_STRIPE_KEY=

# ─────────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────────
PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────
# Cloudflare R2
# ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=master
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=