{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web/api", "run", "dev"],
      "port": 8000
    },
    {
      "name": "web-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web/frontend", "run", "dev"],
      "port": 4321
    },
    {
      "name": "master",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "master", "run", "dev"],
      "port": 4322
    },
    {
      "name": "booking-manager",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "booking-manager", "run", "dev"],
      "port": 3001
    },
    {
      "name": "booking-manager-api",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "PORT=9001 cargo run --manifest-path booking-manager-api/Cargo.toml --bin rust_api"],
      "port": 9001
    }
  ]
}
